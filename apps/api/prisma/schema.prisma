// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DeliverySpeed {
  standard
  express
}

enum TransportMode {
  MINI_VAN
  TRUCK
  AEROPLANE
}

model Customer {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  phone        String
  lat          Float
  lng          Float
  addressLabel String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shippingCalculations ShippingCalculation[]
}

model Seller {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products             Product[]
  shippingCalculations ShippingCalculation[]
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  sellerId  String   @db.Uuid
  name      String
  weightKg  Float
  lengthCm  Float?
  widthCm   Float?
  heightCm  Float?
  priceRs   Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller                Seller                @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  shippingCalculations  ShippingCalculation[]

  @@index([sellerId])
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shippingCalculations ShippingCalculation[]
}

model ShippingCalculation {
  id                   String        @id @default(uuid()) @db.Uuid
  sellerId             String        @db.Uuid
  productId            String        @db.Uuid
  customerId           String        @db.Uuid
  warehouseId          String        @db.Uuid
  deliverySpeed        DeliverySpeed
  sellerToWarehouseKm  Float
  warehouseToCustomerKm Float
  transportMode        TransportMode
  baseShippingRs       Float
  expressExtraRs       Float
  courierRs            Float
  totalRs              Float
  createdAt            DateTime      @default(now())

  seller    Seller    @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([sellerId])
  @@index([productId])
  @@index([customerId])
  @@index([warehouseId])
}
